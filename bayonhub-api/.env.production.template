# Copy this to .env and fill in real values
# Then set these as environment variables in Railway

NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/railway
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379
JWT_SECRET=PASTE_GENERATED_VALUE_FROM_TASK_2
JWT_REFRESH_SECRET=PASTE_GENERATED_VALUE_FROM_TASK_2
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
FRONTEND_URL=https://bayonhub.com

# Fill these when you have the credentials:
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=bayonhub-media
R2_PUBLIC_URL=https://media.bayonhub.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

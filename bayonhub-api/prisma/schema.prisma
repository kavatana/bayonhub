generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  phone               String               @unique
  email               String?              @unique
  passwordHash        String
  name                String
  avatarUrl           String?
  bannerUrl           String?
  province            String?
  slug                String?              @unique
  bio                 String?
  language            String               @default("en")
  role                Role                 @default(USER)
  verificationTier    VerificationTier     @default(NONE)
  isActive            Boolean              @default(true)
  isAdmin             Boolean              @default(false)
  banReason           String?
  bannedUntil         DateTime?
  phoneVerified       Boolean              @default(false)
  isVerifiedSeller    Boolean              @default(false)
  lastSeen            DateTime?
  responseRate        Float?
  telegramChatId      String?
  referralCode        String?              @unique
  plusUntil           DateTime?
  plusExpiredNotifiedAt   DateTime?
  plusExpiringNotifiedAt  DateTime?
  isLifetimePlus      Boolean              @default(false)
  phoneVerifiedAt     DateTime?
  idVerifiedAt        DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  listings            Listing[]
  savedListings       SavedListing[]
  sentMessages        Message[]            @relation("SentMessages")
  buyerConversations  Conversation[]       @relation("BuyerConversations")
  sellerConversations Conversation[]       @relation("SellerConversations")
  reports             Report[]
  leads               Lead[]
  refreshTokens       RefreshToken[]
  payments            Payment[]
  notifications       Notification[]
  kycApplication      KYCApplication?
  merchantProfile     MerchantProfile?
  reviewsGiven        Review[]             @relation("ReviewsGiven")
  reviewsReceived     Review[]             @relation("ReviewsReceived")
  featuredListings    FeaturedListing[]    @relation("AdminFeaturedListings")
  appeals             Appeal[]
  verificationRequest VerificationRequest?
  pushSubscriptions   PushSubscription[]
  followedSellers     Follow[]             @relation("UserFollows")
  sellerFollowers     Follow[]             @relation("SellerFollowers")
  referralsGiven      Referral[]           @relation("ReferralsGiven")
  referralReceived    Referral?            @relation("ReferralReceived")
  plusGifts           PlusGift[]
  adminAuditLogs      AdminAuditLog[]
}

enum Role {
  USER
  SELLER
  ADMIN
}

enum VerificationTier {
  NONE
  PHONE
  IDENTITY
}

model Listing {
  id                String                   @id @default(uuid())
  slug              String                   @unique
  title             String
  titleKm           String?
  description       String
  descriptionKm     String?
  price             Decimal?                 @db.Decimal(12, 2)
  currency          String                   @default("USD")
  negotiable        Boolean                  @default(false)
  condition         String?
  categorySlug      String
  subcategorySlug   String?
  province          String
  district          String?
  addressDetail     String?
  lat               Float?
  lng               Float?
  images            ListingImage[]
  facets            Json?
  status            ListingStatus            @default(ACTIVE)
  promoted          Boolean                  @default(false)
  promotedUntil     DateTime?
  bumpedAt          DateTime?
  urgent            Boolean                  @default(false)
  previousPrice     Decimal?                 @db.Decimal(12, 2)
  discountPercent   Int?
  topSeller         Boolean                  @default(false)
  facebookPage      String?
  imageReviewStatus String                   @default("pending")
  viewCount         Int                      @default(0)
  contactCount      Int                      @default(0)
  expiresAt         DateTime?
  archivedAt        DateTime?
  deletedAt         DateTime?
  isActive          Boolean                  @default(true)
  sellerId          String
  seller            User                     @relation(fields: [sellerId], references: [id])
  savedBy           SavedListing[]
  listingViews      ListingView[]
  leads             Lead[]
  reports           Report[]
  payments          Payment[]
  promotions        ListingPromotion[]
  featuredListing   FeaturedListing?
  reviews           Review[]
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  searchVector      Unsupported("tsvector")? @map("search_vector")

  @@index([categorySlug])
  @@index([province])
  @@index([status])
  @@index([promoted])
  @@index([bumpedAt])
  @@index([createdAt])
  @@index([sellerId])
  @@index([status, deletedAt, createdAt])
  @@index([status, deletedAt, categorySlug, createdAt])
  @@index([status, deletedAt, province, createdAt])
  @@index([status, deletedAt, promoted, createdAt])
  @@index([status, deletedAt, province, district])
  @@index([district])
  @@index([price])
  @@index([viewCount])
}

enum ListingStatus {
  ACTIVE
  PENDING
  REJECTED
  SOLD
  EXPIRED
  REMOVED
  DRAFT
  FLAGGED
  HIDDEN
  DELETED
}

model ListingImage {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  thumbUrl  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ListingView {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sessionId String?
  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([createdAt])
}

model SavedListing {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  savedPrice Decimal? @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  @@unique([userId, listingId])
}

model FeaturedListing {
  id        String    @id @default(uuid())
  listingId String    @unique
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  adminId   String
  admin     User      @relation("AdminFeaturedListings", fields: [adminId], references: [id])
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([listingId])
  @@index([adminId])
}

model Appeal {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  status    String   @default("pending")
  adminNote String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
}

model PhoneOTP {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model VerificationRequest {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  idFrontUrl  String
  idBackUrl   String?
  status      String    @default("pending")
  adminNote   String?
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  @@index([status])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Follow {
  id         String   @id @default(uuid())
  followerId String
  follower   User     @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  sellerId   String
  seller     User     @relation("SellerFollowers", fields: [sellerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([followerId, sellerId])
  @@index([followerId])
  @@index([sellerId])
}

model Referral {
  id          String   @id @default(uuid())
  referrerId  String
  referrer    User     @relation("ReferralsGiven", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId  String   @unique
  referred    User     @relation("ReferralReceived", fields: [referredId], references: [id], onDelete: Cascade)
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([referrerId])
}

model PlusGift {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  giftedBy  String
  giftType  String
  note      String?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Lead {
  id         String   @id @default(uuid())
  listingId  String?
  listing    Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       LeadType
  phone      String?
  message    String?
  offerPrice Decimal? @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
}

enum LeadType {
  CALL
  WHATSAPP
  TELEGRAM
  CHAT
  OFFER
}

model Conversation {
  id        String    @id @default(uuid())
  listingId String?
  buyerId   String
  buyer     User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId  String
  seller    User      @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@unique([listingId, buyerId, sellerId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  body           String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
}

model Report {
  id                String       @id @default(uuid())
  listingId         String
  listing           Listing      @relation(fields: [listingId], references: [id])
  reporterId        String
  reporter          User         @relation(fields: [reporterId], references: [id])
  reason            ReportReason
  detail            String?
  evidenceUrl       String?
  contactEmail      String?
  userAgent         String?
  reporterSessionId String?
  listingTitle      String?
  status            ReportStatus @default(PENDING)
  resolvedAt        DateTime?
  createdAt         DateTime     @default(now())
}

enum ReportReason {
  SCAM
  WRONG_CATEGORY
  INAPPROPRIATE
  SPAM
  DUPLICATE
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Payment {
  id             String            @id @default(uuid())
  reference      String            @unique
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId      String?
  listing        Listing?          @relation(fields: [listingId], references: [id], onDelete: SetNull)
  promotion      ListingPromotion?
  plan           PromotionPlan
  amount         Decimal           @db.Decimal(10, 2)
  currency       String            @default("USD")
  status         PaymentStatus     @default(PENDING)
  screenshotUrl  String?
  note           String?
  reviewedBy     String?
  reviewNote     String?
  reviewedAt     DateTime?
  khqrPayload    String?
  webhookPayload Json?
  paidAt         DateTime?
  refundNote     String?
  refundedAt     DateTime?
  refundedByAdminId String?
  expiresAt      DateTime
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userId])
  @@index([listingId])
  @@index([status])
}

enum PromotionPlan {
  BOOST
  TOP_AD
  VIP_30
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  EXPIRED
  REFUNDED
  FAILED
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

model ListingPromotion {
  id        String        @id @default(uuid())
  listingId String
  listing   Listing       @relation(fields: [listingId], references: [id])
  paymentId String        @unique
  payment   Payment       @relation(fields: [paymentId], references: [id])
  plan      PromotionPlan
  startedAt DateTime      @default(now())
  expiresAt DateTime
  active    Boolean       @default(true)

  @@index([listingId])
  @@index([active])
}

model KYCApplication {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  idType      IDType
  idNumber    String
  idFrontKey  String
  idBackKey   String?
  selfieKey   String?
  status      KYCStatus @default(PENDING)
  reviewNote  String?
  reviewedBy  String?
  reviewedAt  DateTime?
  submittedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

enum IDType {
  NATIONAL_ID
  PASSPORT
  DRIVING_LICENSE
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_RESUBMIT
}

model MerchantProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName      String
  storeNameKm    String?
  tagline        String?
  taglineKm      String?
  bannerKey      String?
  logoKey        String?
  businessPhone  String?
  telegramHandle String?
  facebookPage   String?
  businessHours  Json?
  aboutUs        String?
  aboutUsKm      String?
  taxId          String?
  catalogConfig  Json?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Review {
  id         String   @id @default(uuid())
  rating     Int      @default(5)
  comment    String?
  reviewerId String
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  sellerId   String
  seller     User     @relation("ReviewsReceived", fields: [sellerId], references: [id])
  listingId  String?
  listing    Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sellerId])
  @@index([reviewerId])
}

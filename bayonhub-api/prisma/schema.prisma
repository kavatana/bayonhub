generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(uuid())
  phone            String           @unique
  email            String?          @unique
  passwordHash     String
  name             String
  avatarUrl        String?
  bio              String?
  language         String           @default("en")
  role             Role             @default(USER)
  verificationTier VerificationTier @default(NONE)
  isActive         Boolean          @default(true)
  phoneVerifiedAt  DateTime?
  idVerifiedAt     DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  listings         Listing[]
  savedListings    SavedListing[]
  sentMessages     Message[]        @relation("SentMessages")
  receivedMessages Message[]        @relation("ReceivedMessages")
  reports          Report[]
  leads            Lead[]
  refreshTokens    RefreshToken[]
  payments         Payment[]
  kycApplication   KYCApplication?
  merchantProfile  MerchantProfile?
}

enum Role {
  USER
  SELLER
  ADMIN
}

enum VerificationTier {
  NONE
  PHONE
  IDENTITY
}

model Listing {
  id              String                   @id @default(uuid())
  slug            String                   @unique
  title           String
  titleKm         String?
  description     String
  descriptionKm   String?
  price           Decimal?                 @db.Decimal(12, 2)
  currency        String                   @default("USD")
  negotiable      Boolean                  @default(false)
  condition       String?
  categorySlug    String
  subcategorySlug String?
  province        String
  district        String?
  addressDetail   String?
  lat             Float?
  lng             Float?
  images          ListingImage[]
  facets          Json?
  status          ListingStatus            @default(ACTIVE)
  promoted        Boolean                  @default(false)
  promotedUntil   DateTime?
  urgent          Boolean                  @default(false)
  previousPrice   Decimal?                 @db.Decimal(12, 2)
  discountPercent Int?
  topSeller       Boolean                  @default(false)
  facebookPage    String?
  viewCount       Int                      @default(0)
  contactCount    Int                      @default(0)
  sellerId        String
  seller          User                     @relation(fields: [sellerId], references: [id])
  savedBy         SavedListing[]
  leads           Lead[]
  reports         Report[]
  payments        Payment[]
  promotions      ListingPromotion[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  searchVector    Unsupported("tsvector")? @map("search_vector")

  @@index([categorySlug])
  @@index([province])
  @@index([status])
  @@index([promoted])
  @@index([createdAt])
  @@index([sellerId])
}

enum ListingStatus {
  ACTIVE
  SOLD
  EXPIRED
  REMOVED
  DRAFT
}

model ListingImage {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  thumbUrl  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model SavedListing {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  savedPrice Decimal? @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  @@unique([userId, listingId])
}

model Lead {
  id         String   @id @default(uuid())
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  type       LeadType
  phone      String?
  message    String?
  offerPrice Decimal? @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
}

enum LeadType {
  CALL
  WHATSAPP
  TELEGRAM
  CHAT
  OFFER
}

model Message {
  id         String    @id @default(uuid())
  senderId   String
  sender     User      @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User      @relation("ReceivedMessages", fields: [receiverId], references: [id])
  listingId  String?
  body       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([senderId, receiverId])
}

model Report {
  id         String       @id @default(uuid())
  listingId  String
  listing    Listing      @relation(fields: [listingId], references: [id])
  reporterId String
  reporter   User         @relation(fields: [reporterId], references: [id])
  reason     ReportReason
  detail     String?
  status     ReportStatus @default(PENDING)
  resolvedAt DateTime?
  createdAt  DateTime     @default(now())
}

enum ReportReason {
  SCAM
  WRONG_CATEGORY
  INAPPROPRIATE
  SPAM
  DUPLICATE
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Payment {
  id             String            @id @default(uuid())
  reference      String            @unique
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  listingId      String?
  listing        Listing?          @relation(fields: [listingId], references: [id])
  promotion      ListingPromotion?
  plan           PromotionPlan
  amount         Decimal           @db.Decimal(10, 2)
  currency       String            @default("USD")
  status         PaymentStatus     @default(PENDING)
  khqrPayload    String?
  webhookPayload Json?
  paidAt         DateTime?
  expiresAt      DateTime
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userId])
  @@index([listingId])
  @@index([status])
}

enum PromotionPlan {
  BOOST
  TOP_AD
  VIP_30
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  REFUNDED
  FAILED
}

model ListingPromotion {
  id        String        @id @default(uuid())
  listingId String
  listing   Listing       @relation(fields: [listingId], references: [id])
  paymentId String        @unique
  payment   Payment       @relation(fields: [paymentId], references: [id])
  plan      PromotionPlan
  startedAt DateTime      @default(now())
  expiresAt DateTime
  active    Boolean       @default(true)

  @@index([listingId])
  @@index([active])
}

model KYCApplication {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  fullName    String
  idType      IDType
  idNumber    String
  idFrontKey  String
  idBackKey   String?
  selfieKey   String?
  status      KYCStatus @default(PENDING)
  reviewNote  String?
  reviewedBy  String?
  reviewedAt  DateTime?
  submittedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

enum IDType {
  NATIONAL_ID
  PASSPORT
  DRIVING_LICENSE
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_RESUBMIT
}

model MerchantProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields:[userId], references:[id])
  storeName       String
  storeNameKm     String?
  tagline         String?
  taglineKm       String?
  bannerKey       String?
  logoKey         String?
  businessPhone   String?
  telegramHandle  String?
  facebookPage    String?
  businessHours   Json?
  aboutUs         String?
  aboutUsKm       String?
  taxId           String?
  catalogConfig   Json?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
